{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CrossBridge",
  "version": "0.1.0",
  "identifier": "dev.crossbridge.windows",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CrossBridge",
        "width": 1100,
        "height": 760,
        "minWidth": 760,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "signCommand": "cmd /c \"if exist \\\"%TAURI_WIN_SIGNING_PFX_PATH%\\\" (signtool sign /f \\\"%TAURI_WIN_SIGNING_PFX_PATH%\\\" /p \\\"%TAURI_WIN_SIGNING_PFX_PASSWORD%\\\" /fd sha256 /tr http://timestamp.digicert.com /td sha256 %1) else (echo Code signing certificate not found, skipping: %1)\""
    }
  }
}
